<section class="relative min-h-screen flex items-center overflow-hidden bg-gray-950">
  <div class="absolute inset-0" data-parallax>
    <div class="absolute inset-0 bg-gradient-to-br from-gray-900/90 via-gray-950/80 to-gray-950/90" />
    <img
      src="https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?w=1400&q=80"
      alt=""
      class="h-full w-full object-cover"
      loading="eager"
      aria-hidden="true"
    />
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 pt-24 pb-16 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <p class="mb-4 font-display text-lg italic text-brand-400" data-animate="hero-title">Welcome to Anaedo Global</p>
        <h1 class="font-display text-4xl font-bold leading-tight text-white sm:text-5xl lg:text-6xl" data-animate="hero-title">
          Premium Tiles &amp; Doors for<br />
          <span class="text-brand-400">Timeless Spaces</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-gray-300" data-animate="hero-subtitle">
          From exquisite ceramic tiles to solid wood doors, we bring your vision to life with quality craftsmanship and unmatched elegance.
        </p>
        <div class="mt-8 flex flex-wrap gap-4" data-animate="hero-cta">
          <a href="#products" class="btn-primary bg-brand-500 hover:bg-brand-600 text-base px-8 py-4">Explore Products</a>
          <a href="#contact" class="btn-outline-light text-base px-8 py-4">Request a Quote</a>
        </div>
      </div>

      <div class="hidden lg:block" data-animate="hero-image">
        <div class="relative">
          <div class="aspect-[4/3] overflow-hidden rounded-2xl border border-white/10">
            <img
              src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=600&q=80"
              alt="Elegant tiled interior showcasing premium tile installation"
              class="h-full w-full object-cover"
              loading="eager"
            />
          </div>
          <div class="absolute -bottom-6 -left-6 rounded-xl border border-white/10 bg-white/10 p-4 backdrop-blur-md">
            <p class="text-3xl font-bold text-white" data-count="150" data-suffix="+">150+</p>
            <p class="text-sm text-gray-300">Projects Completed</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 z-10 hidden -translate-x-1/2 animate-bounce lg:block">
    <a href="#products" aria-label="Scroll to products">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/60"><path d="m6 9 6 6 6-6"/></svg>
    </a>
  </div>
</section>
